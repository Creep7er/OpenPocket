}


static func measure(text: String, scale: int = 2) -> Vector2i:
	var lines := text.to_upper().split("\n")
	var width := 0
	for line in lines:
		width = maxi(width, line.length() * (CHAR_W + GAP) - GAP)
	return Vector2i(width * scale, lines.size() * (CHAR_H + GAP) * scale - GAP * scale)


static func draw_text(canvas: CanvasItem, pos: Vector2, text: String, color: Color, scale: int = 2) -> void:
	var y := int(pos.y)
	for line in text.to_upper().split("\n"):
		var x := int(pos.x)
		for index in range(line.length()):
			draw_char(canvas, Vector2i(x, y), line.substr(index, 1), color, scale)
			x += (CHAR_W + GAP) * scale
		y += (CHAR_H + GAP) * scale


static func draw_char(canvas: CanvasItem, pos: Vector2i, character: String, color: Color, scale: int = 2) -> void:
	var glyph: Array = GLYPHS.get(character.to_upper(), GLYPHS[" "])
	for row in range(CHAR_H):
		var bits: String = glyph[row]
		for col in range(CHAR_W):
			if bits.substr(col, 1) == "1":
				canvas.draw_rect(Rect2(pos + Vector2i(col * scale, row * scale), Vector2(scale, scale)), color, true)
