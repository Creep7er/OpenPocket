; Engine configuration file.
; PopugVPocket targets Godot 4.x without .NET.

config_version=5

[application]

config/name="PopugVPocket"
config/description="A pixel handheld platform by Popugonet."
config/version="0.5.1"
run/main_scene="res://app/main.tscn"
config/features=PackedStringArray("4.2")
config/icon="res://app/assets/branding/popugvpocket-mark.png"

[autoload]

BrandConfig="*res://app/runtime/branding/brand_config.gd"
PocketScreen="*res://app/runtime/screen/pocket_screen.gd"
ConsoleLayoutManager="*res://app/runtime/layout/console_layout_manager.gd"
PocketInput="*res://app/runtime/input/pocket_input.gd"
PocketRouter="*res://app/runtime/system/pocket_router.gd"
PocketStorage="*res://app/runtime/storage/pocket_storage.gd"
PocketFilePicker="*res://app/runtime/files/pocket_file_picker.gd"
LegacyBackupImporter="*res://app/runtime/migration/legacy_backup_importer.gd"
CartridgeManager="*res://app/runtime/cartridges/cartridge_manager.gd"
AchievementManager="*res://app/runtime/achievements/achievement_manager.gd"
CartridgeAchievements="*res://app/runtime/achievements/cartridge_achievements.gd"
CosmeticsManager="*res://app/runtime/cosmetics/cosmetics_manager.gd"
PocketPackages="*res://app/runtime/packages/pocket_packages.gd"
PocketSystem="*res://app/runtime/system/pocket_system.gd"
PocketAudio="*res://app/runtime/audio/pocket_audio.gd"
CartridgeAudio="*res://app/runtime/audio/cartridge_audio.gd"
PocketTheme="*res://app/ui/themes/theme_manager.gd"
StoreService="*res://app/runtime/store/store_service.gd"

[display]

window/size/viewport_width=540
window/size/viewport_height=960
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"
window/handheld/orientation=1

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
renderer/rendering_method="mobile"

[input]

