{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://popugvpocket.dev/schemas/package.schema.json",
  "title": "PopugVPocket package manifest",
  "type": "object",
  "required": ["id", "name", "version", "type", "entry_scene", "sdk_version", "author"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "type": {"type": "string", "enum": ["game", "app", "theme", "firmware", "skill"]},
    "entry_scene": {"type": "string", "minLength": 1},
    "sdk_version": {"type": "string", "minLength": 1, "description": "PopugVPocket package API version. Current experimental API: 0.5.0."},
    "description": {"type": "string"},
    "category": {"type": "string"},
    "license": {"type": "string"},
    "capabilities": {"type": "array", "items": {"type": "string"}},
    "settings": {"type": "array", "description": "Optional package setting metadata for SDK tools."},
    "author": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
